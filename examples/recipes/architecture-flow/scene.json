{
  "slug": "architecture-flow",
  "title": "MCP Architecture Flow",
  "category": "Architecture/explanation",
  "purpose": "Turn an architecture diagram into geometry: user, agent, queue, and Octane as spatial blocks connected by flow lines.",
  "prompt": "Explain how Hermes MCP commands become Octane scene updates.",
  "camera": {
    "position": [
      2.8,
      -5.2,
      2.6
    ],
    "target": [
      0,
      0,
      0.5
    ],
    "fov": 36
  },
  "commands": [
