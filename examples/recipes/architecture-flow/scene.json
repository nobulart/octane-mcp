        "kind": "glossy",
        "color": [
          0.05,
          0.75,
          1.0
        ],
        "roughness": 0.22
      }
    },
    {
      "op": "set_camera",
      "payload": {
        "position": [
          2.8,
          -5.2,
          2.6
        ],
        "target": [
          0,
          0,
          0.5
        ],
        "fov": 36
      }
    },
    {
      "op": "set_lighting",
      "payload": {
        "preset": "soft_studio"
      }
    },
    {
      "op": "start_render",
      "payload": {
        "samples": 128,
        "width": 1280,
        "height": 1280
      }
    },
    {
      "op": "save_preview",
      "payload": {
        "path": "examples/recipes/architecture-flow/octane-preview.png",
