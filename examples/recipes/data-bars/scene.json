{
  "slug": "data-bars",
  "title": "3D KPI Bar Chart",
  "category": "Data visualization",
  "purpose": "Compare a short numeric sequence as spatial bars with a clear baseline and highlight bars above threshold.",
  "prompt": "Visualize quarterly or experiment metrics as a 3D bar chart, highlighting unusually high values.",
  "camera": {
    "position": [
      4.2,
      -5.0,
      3.0
    ],
    "target": [
      0,
      0,
      0.8
    ],
    "fov": 45
  },
  "materials": {
    "base": {
      "kind": "diffuse",
      "color": [
        0.1373,
        0.1765,
        0.2941
      ],
      "roughness": 0.55
    },
    "cyan": {
      "kind": "glossy",
      "color": [
        0.0706,
        0.7725,
        1.0
      ],
      "roughness": 0.25
    },
    "gold": {
      "kind": "glossy",
      "color": [
        1.0,
        0.7098,
        0.2392
      ],
      "roughness": 0.18
    },
    "white": {
      "kind": "glossy",
      "color": [
        0.902,
        0.9333,
        1.0
      ],
      "roughness": 0.25
    }
  },
  "commands": [
    {
      "op": "import_geometry",
      "payload": {
        "path": "examples/recipes/data-bars/scene.obj",
        "format": "obj",
        "name": "data-bars"
      }
    },
    {
      "op": "create_material",
      "payload": {
        "name": "base",
        "kind": "diffuse",
        "color": [
          0.1373,
          0.1765,
          0.2941
        ],
        "roughness": 0.55
      }
    },
    {
      "op": "create_material",
      "payload": {
        "name": "cyan",
        "kind": "glossy",
        "color": [
          0.0706,
          0.7725,
          1.0
        ],
        "roughness": 0.25
      }
    },
    {
      "op": "create_material",
      "payload": {
        "name": "gold",
        "kind": "glossy",
        "color": [
          1.0,
          0.7098,
          0.2392
        ],
        "roughness": 0.18
      }
    },
    {
      "op": "create_material",
      "payload": {
        "name": "white",
        "kind": "glossy",
        "color": [
          0.902,
          0.9333,
          1.0
        ],
        "roughness": 0.25
      }
    },
    {
      "op": "set_camera",
      "payload": {
        "position": [
          4.2,
          -5.0,
          3.0
        ],
        "target": [
          0,
          0,
          0.8
        ],
        "fov": 45
      }
    },
    {
      "op": "set_lighting",
      "payload": {
        "preset": "soft_studio"
      }
    },
    {
      "op": "start_render",
      "payload": {
        "samples": 128,
        "width": 1280,
        "height": 1280
      }
    },
    {
      "op": "save_preview",
      "payload": {
        "path": "examples/recipes/data-bars/octane-preview.png",
        "width": 1280,
        "height": 1280
      }
    }
  ],
  "preview_note": "preview.png is a lightweight repo-generated raster preview; re-render in Octane for final quality.",
  "native_render_note": "Some teaching assets use OBJ line primitives for paths/arrows. If the Octane OBJ importer drops lines, convert those paths to thin cylinders/tubes before final native rendering.",
  "quality_checklist": [
    "Preview is non-blank and the central idea is recognizable at thumbnail size.",
    "Scene imports the local scene.obj path listed in commands[].",
    "Camera frames the entire subject with margin.",
    "Materials named in OBJ usemtl statements are documented in scene.mtl and scene.json.",
    "If native Octane output differs from preview.png, record the lesson in docs/recipe-book.md."
  ]
}