{
  "slug": "document-ocr-layout",
  "title": "Document OCR Layout Inspection",
  "category": "Document AI/OCR",
  "purpose": "Represent OCR/document-layout output as raised boxes for text lines, tables, images, and uncertain detections.",
  "prompt": "Visualize a document parser result with text regions, table cells, image regions, and a highlighted low-confidence area.",
  "camera": {
    "position": [
      4.0,
      -6.2,
      5.2
    ],
    "target": [
      0,
      0,
      0.25
    ],
    "fov": 42
  },
  "materials": {
    "base": {
      "kind": "diffuse",
      "color": [
        0.1373,
        0.1765,
        0.2941
      ],
      "roughness": 0.55
    },
    "paper": {
      "kind": "glossy",
      "color": [
        0.9333,
        0.9255,
        0.8784
      ],
      "roughness": 0.25
    },
    "ink": {
      "kind": "glossy",
      "color": [
        0.0784,
        0.098,
        0.1647
      ],
      "roughness": 0.25
    },
    "ocr_text": {
      "kind": "glossy",
      "color": [
        0.2078,
        0.4588,
        1.0
      ],
      "roughness": 0.25
    },
    "ocr_table": {
      "kind": "glossy",
      "color": [
        0.2941,
        0.8627,
        0.549
      ],
      "roughness": 0.25
    },
    "ocr_image": {
      "kind": "glossy",
      "color": [
        1.0,
        0.7098,
        0.2392
      ],
      "roughness": 0.25
    },
    "ocr_warning": {
      "kind": "glossy",
      "color": [
        1.0,
        0.2667,
        0.3765
      ],
      "roughness": 0.25
    }
  },
  "commands": [
    {
      "op": "import_geometry",
      "payload": {
        "path": "examples/recipes/document-ocr-layout/scene.obj",
        "format": "obj",
        "name": "document-ocr-layout"
      }
    },
    {
      "op": "create_material",
      "payload": {
        "name": "base",
        "kind": "diffuse",
        "color": [
          0.1373,
          0.1765,
          0.2941
        ],
        "roughness": 0.55
      }
    },
    {
      "op": "create_material",
      "payload": {
        "name": "paper",
        "kind": "glossy",
        "color": [
          0.9333,
          0.9255,
          0.8784
        ],
        "roughness": 0.25
      }
    },
    {
      "op": "create_material",
      "payload": {
        "name": "ink",
        "kind": "glossy",
        "color": [
          0.0784,
          0.098,
          0.1647
        ],
        "roughness": 0.25
      }
    },
    {
      "op": "create_material",
      "payload": {
        "name": "ocr_text",
        "kind": "glossy",
        "color": [
          0.2078,
          0.4588,
          1.0
        ],
        "roughness": 0.25
      }
    },
    {
      "op": "create_material",
      "payload": {
        "name": "ocr_table",
        "kind": "glossy",
        "color": [
          0.2941,
          0.8627,
          0.549
        ],
        "roughness": 0.25
      }
    },
    {
      "op": "create_material",
      "payload": {
        "name": "ocr_image",
        "kind": "glossy",
        "color": [
          1.0,
          0.7098,
          0.2392
        ],
        "roughness": 0.25
      }
    },
    {
      "op": "create_material",
      "payload": {
        "name": "ocr_warning",
        "kind": "glossy",
        "color": [
          1.0,
          0.2667,
          0.3765
        ],
        "roughness": 0.25
      }
    },
    {
      "op": "set_camera",
      "payload": {
        "position": [
          4.0,
          -6.2,
          5.2
        ],
        "target": [
          0,
          0,
          0.25
        ],
        "fov": 42
      }
    },
    {
      "op": "set_lighting",
      "payload": {
        "preset": "soft_studio"
      }
    },
    {
      "op": "start_render",
      "payload": {
        "samples": 128,
        "width": 1280,
        "height": 1280
      }
    },
    {
      "op": "save_preview",
      "payload": {
        "path": "examples/recipes/document-ocr-layout/octane-preview.png",
        "width": 1280,
        "height": 1280
      }
    }
  ],
  "preview_note": "preview.png is a lightweight repo-generated raster preview; re-render in Octane for final quality.",
  "native_render_note": "This recipe compiles semantic analysis artifacts to OBJ geometry. Native Octane success requires bridge result metadata plus an inspected octane-preview.png.",
  "known_pitfalls": [
    "OCR coordinate systems often use top-left origins; normalize axes before generating geometry.",
    "Thin boxes can z-fight with the page plane; keep raised overlays above the paper surface.",
    "Too many text boxes can clutter the scene; group or downsample rows for previews."
  ],
  "quality_checklist": [
    "Preview is non-blank and the central idea is recognizable at thumbnail size.",
    "Scene imports the local scene.obj path listed in commands[].",
    "Camera frames the entire subject with margin.",
    "Materials named in OBJ usemtl statements are documented in scene.mtl and scene.json.",
    "Native Octane output must be saved as octane-preview.png before claiming native render success."
  ],
  "native_octane_verified": false,
  "target_preview": "preview.png",
  "visual_iteration_protocol": {
    "model": "ollama:glm-ocr",
    "reference_image": "examples/recipes/document-ocr-layout/preview.png",
    "candidate_image": "examples/recipes/document-ocr-layout/octane-preview.png",
    "max_iterations": 4,
    "review_focus": [
      "object count and semantic content",
      "composition, framing, and camera perspective",
      "material/color readability and contrast",
      "lighting, shadows, and background clarity",
      "task-specific labels, legends, or focal details"
    ],
    "patch_dimensions": [
      "geometry",
      "camera",
      "lighting",
      "materials",
      "render_settings"
    ],
    "required_evidence": [
      "bridge result metadata for queued commands",
      "native Octane candidate preview at octane-preview.png",
      "glm-ocr reference and candidate review notes",
      "one bounded patch plan per iteration",
      "final native Octane render bundled as octane-preview.png",
      "iteration review/patch records under iterations/"
    ],
    "stop_conditions": [
      "candidate content and major silhouettes match the reference or stated recipe intent",
      "task-critical colors/materials/labels are visually distinguishable",
      "camera/framing and lighting are close enough for the task",
      "remaining gaps require bridge schema or native material capability work"
    ],
    "baseline_sweep": {
      "enabled": true,
      "purpose": "Rapidly disambiguate scene orientation/camera framing before fine visual matching.",
      "camera_or_scene_variants": [
        {
          "name": "front",
          "azimuth_degrees": 0,
          "elevation_degrees": 12
        },
        {
          "name": "left_three_quarter",
          "azimuth_degrees": -35,
          "elevation_degrees": 12
        },
        {
          "name": "right_three_quarter",
          "azimuth_degrees": 35,
          "elevation_degrees": 12
        },
        {
          "name": "top_oblique",
          "azimuth_degrees": 0,
          "elevation_degrees": 45
        }
      ],
      "visual_grammar_axes": [
        "orientation",
        "camera_distance",
        "focal_length",
        "lighting_direction",
        "material/readability contrast"
      ],
      "evidence_pattern": "iterations/baseline-<variant>.png plus iterations/baseline-review.json"
    }
  },
  "final_bundle": {
    "required": true,
    "native_render": "examples/recipes/document-ocr-layout/octane-preview.png",
    "iteration_dir": "examples/recipes/document-ocr-layout/iterations",
    "final_review": "examples/recipes/document-ocr-layout/iterations/final-review.json",
    "result_metadata_pattern": "workspace/results/<command_id>.json copied or summarized into iterations/",
    "bundled_assets": [
      "scene.obj",
      "scene.mtl",
      "scene.json",
      "preview.png",
      "octane-preview.png",
      "iterations/*.json",
      "iterations/*.png",
      "assets/*"
    ],
    "status": "pending_native_octane_iteration",
    "note": "The final iterated native Octane render and all reproduction assets should be checked in with this recipe before marking native_octane_verified true."
  }
}