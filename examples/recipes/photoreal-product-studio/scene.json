        "name": "photoreal-product-studio"
      }
    },
    {
      "op": "set_camera",
      "payload": {
        "position": [
          2.6,
          -4.2,
          2.0
        ],
        "target": [
          0.05,
          -0.35,
          0.85
        ],
        "fov": 38
      }
