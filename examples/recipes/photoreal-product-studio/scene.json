      }
    },
    {
      "op": "start_render",
      "payload": {
        "samples": 512,
        "width": 1280,
        "height": 720
      }
    },
    {
      "op": "save_preview",
      "payload": {
        "path": "examples/recipes/photoreal-product-studio/octane-preview.png",
