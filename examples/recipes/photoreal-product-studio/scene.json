{
  "slug": "photoreal-product-studio",
  "title": "Photoreal Product Studio",
  "category": "Photoreal/PBR rendering",
  "purpose": "Demonstrate a high-quality product-rendering target scene with glass, metal, softboxes, pedestal, and cyclorama backdrop.",
  "preview_note": "photoreal-preview.png is a generated target/reference render, not a verified Octane output. Re-render the OBJ/MTL scene in Octane X for native validation.",
  "camera": {
    "position": [
      2.6,
      -4.2,
      2.0
    ],
    "target": [
      0.05,
      -0.35,
      0.85
    ],
    "fov": 38
  },
  "lighting": {
    "preset": "soft_studio",
    "intent": "large softboxes left/right, dark studio, glossy reflections, shallow depth-of-field"
  },
  "materials": {
    "mat_cyan_glass": {
      "kind": "specular/glass",
      "color": [
        0.05,
        0.75,
        1.0
      ],
      "transmission": 0.7,
      "roughness": 0.03,
      "ior": 1.45
    },
    "mat_brushed_gold": {
      "kind": "metallic",
      "color": [
        1.0,
        0.62,
        0.16
      ],
      "metallic": 1.0,
      "roughness": 0.18
    },
    "mat_pedestal": {
      "kind": "matte",
      "color": [
        0.12,
        0.12,
        0.13
      ],
      "roughness": 0.55
    },
    "mat_charcoal": {
      "kind": "matte backdrop",
      "color": [
        0.025,
        0.028,
        0.035
      ],
      "roughness": 0.7
    },
    "mat_light_panel": {
      "kind": "emissive area-light proxy",
      "color": [
        1.0,
        0.96,
        0.86
      ],
      "power": 4.0
    }
  },
  "quality_checklist": [
    "Target/reference image is visibly photoreal and free of text/watermarks.",
    "Native Octane output must be saved as octane-preview.png before claiming native photoreal success.",
    "Glass cube shows transmission/refraction rather than opaque cyan plastic.",
    "Gold sphere shows metallic reflections and manageable roughness.",
    "Softbox/cyclorama framing keeps product centered with realistic shadows."
  ],
  "commands": [
    {
      "op": "import_geometry",
      "payload": {
        "path": "examples/recipes/photoreal-product-studio/scene.obj",
        "format": "obj",
        "name": "photoreal-product-studio"
      }
    },
    {
      "op": "create_material",
      "payload": {
        "name": "mat_charcoal",
        "kind": "diffuse",
        "color": [
          0.025,
          0.028,
          0.035
        ],
        "roughness": 0.7
      }
    },
    {
      "op": "create_material",
      "payload": {
        "name": "mat_pedestal",
        "kind": "diffuse",
        "color": [
          0.12,
          0.12,
          0.13
        ],
        "roughness": 0.55
      }
    },
    {
      "op": "create_material",
      "payload": {
        "name": "mat_cyan_glass",
        "kind": "specular",
        "color": [
          0.05,
          0.75,
          1.0
        ],
        "roughness": 0.03,
        "transmission": 0.7,
        "ior": 1.45
      }
    },
    {
      "op": "create_material",
      "payload": {
        "name": "mat_brushed_gold",
        "kind": "metallic",
        "color": [
          1.0,
          0.62,
          0.16
        ],
        "roughness": 0.18,
        "metallic": 1.0
      }
    },
    {
      "op": "create_material",
      "payload": {
        "name": "mat_light_panel",
        "kind": "diffuse",
        "color": [
          1.0,
          0.96,
          0.86
        ]
      }
    },
    {
      "op": "assign_material",
      "payload": {
        "object_name": "photoreal-product-studio",
        "material_name": "mat_charcoal",
        "group_index": 1
      }
    },
    {
      "op": "assign_material",
      "payload": {
        "object_name": "photoreal-product-studio",
        "material_name": "mat_pedestal",
        "group_index": 2
      }
    },
    {
      "op": "assign_material",
      "payload": {
        "object_name": "photoreal-product-studio",
        "material_name": "mat_cyan_glass",
        "group_index": 3
      }
    },
    {
      "op": "assign_material",
      "payload": {
        "object_name": "photoreal-product-studio",
        "material_name": "mat_brushed_gold",
        "group_index": 4
      }
    },
    {
      "op": "assign_material",
      "payload": {
        "object_name": "photoreal-product-studio",
        "material_name": "mat_light_panel",
        "group_index": 5
      }
    },
    {
      "op": "set_camera",
      "payload": {
        "position": [
          2.6,
          -4.2,
          2.0
        ],
        "target": [
          0.05,
          -0.35,
          0.85
        ],
        "fov": 38
      }
    },
    {
      "op": "set_lighting",
      "payload": {
        "preset": "soft_studio"
      }
    },
    {
      "op": "start_render",
      "payload": {
        "samples": 512,
        "width": 1280,
        "height": 720
      }
    },
    {
      "op": "save_preview",
      "payload": {
        "path": "examples/recipes/photoreal-product-studio/octane-preview.png",
        "width": 1280,
        "height": 720
      }
    }
  ],
  "target_preview": "photoreal-preview.png",
  "visual_iteration_protocol": {
    "model": "ollama:glm-ocr",
    "reference_image": "examples/recipes/photoreal-product-studio/photoreal-preview.png",
    "candidate_image": "examples/recipes/photoreal-product-studio/octane-preview.png",
    "max_iterations": 4,
    "review_focus": [
      "object count and semantic content",
      "composition, framing, and camera perspective",
      "material/color readability and contrast",
      "lighting, shadows, and background clarity",
      "task-specific labels, legends, or focal details"
    ],
    "patch_dimensions": [
      "geometry",
      "camera",
      "lighting",
      "materials",
      "render_settings"
    ],
    "required_evidence": [
      "bridge result metadata for queued commands",
      "native Octane candidate preview at octane-preview.png",
      "glm-ocr reference and candidate review notes",
      "one bounded patch plan per iteration",
      "final native Octane render bundled as octane-preview.png",
      "iteration review/patch records under iterations/"
    ],
    "stop_conditions": [
      "candidate content and major silhouettes match the reference or stated recipe intent",
      "task-critical colors/materials/labels are visually distinguishable",
      "camera/framing and lighting are close enough for the task",
      "remaining gaps require bridge schema or native material capability work"
    ],
    "baseline_sweep": {
      "enabled": true,
      "purpose": "Rapidly disambiguate scene orientation/camera framing before fine visual matching.",
      "camera_or_scene_variants": [
        {
          "name": "front",
          "azimuth_degrees": 0,
          "elevation_degrees": 12
        },
        {
          "name": "left_three_quarter",
          "azimuth_degrees": -35,
          "elevation_degrees": 12
        },
        {
          "name": "right_three_quarter",
          "azimuth_degrees": 35,
          "elevation_degrees": 12
        },
        {
          "name": "top_oblique",
          "azimuth_degrees": 0,
          "elevation_degrees": 45
        }
      ],
      "visual_grammar_axes": [
        "orientation",
        "camera_distance",
        "focal_length",
        "lighting_direction",
        "material/readability contrast"
      ],
      "evidence_pattern": "iterations/baseline-<variant>.png plus iterations/baseline-review.json"
    }
  },
  "final_bundle": {
    "required": true,
    "native_render": "examples/recipes/photoreal-product-studio/octane-preview.png",
    "iteration_dir": "examples/recipes/photoreal-product-studio/iterations",
    "final_review": "examples/recipes/photoreal-product-studio/iterations/final-review.json",
    "result_metadata_pattern": "workspace/results/<command_id>.json copied or summarized into iterations/",
    "bundled_assets": [
      "scene.obj",
      "scene.mtl",
      "scene.json",
      "photoreal-preview.png",
      "octane-preview.png",
      "iterations/*.json",
      "iterations/*.png",
      "assets/*"
    ],
    "status": "pending_native_octane_iteration",
    "note": "The final iterated native Octane render and all reproduction assets should be checked in with this recipe before marking native_octane_verified true."
  }
}