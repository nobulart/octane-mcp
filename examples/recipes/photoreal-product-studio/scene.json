    "mat_brushed_gold": {
      "kind": "metallic",
      "color": [
        1.0,
        0.62,
        0.16
      ],
      "metallic": 1.0,
      "roughness": 0.18
    },
    "mat_pedestal": {
      "kind": "matte",
      "color": [
        0.12,
        0.12,
        0.13
      ],
      "roughness": 0.55
    },
    "mat_charcoal": {
      "kind": "matte backdrop",
      "color": [
        0.025,
        0.028,
        0.035
      ],
      "roughness": 0.7
    }
  },
  "commands": [
    {
      "op": "import_geometry",
      "payload": {
        "path": "examples/recipes/photoreal-product-studio/scene.obj",
