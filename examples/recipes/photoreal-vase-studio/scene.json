{
  "slug": "photoreal-vase-studio",
  "title": "Photoreal Multi-Vase Studio",
  "category": "Photoreal/PBR rendering",
  "purpose": "A studio product visualization recipe for several vases with deliberately different color, texture, and material: smoky glass, cobalt ceramic, ribbed terracotta, white porcelain, and dark brushed metal.",
  "prompt": "Create a high-end catalog render of five distinct vases on a matte pedestal with softbox reflections and a warm neutral cyclorama backdrop.",
  "preview_note": "photoreal-preview.png is an AI-generated target/reference image plus deterministic OBJ scene geometry; native Octane success requires octane-preview.png and result metadata.",
  "target_preview": "photoreal-preview.png",
  "native_octane_verified": true,
  "camera": {
    "position": [
      3.2,
      -5.0,
      2.15
    ],
    "target": [
      0.05,
      -0.05,
      0.9
    ],
    "fov": 34
  },
  "lighting": {
    "preset": "soft_studio",
    "intent": "large side softboxes, warm overhead strip, broad soft shadows, visible glossy/specular highlights"
  },
  "materials": {
    "mat_smoky_glass": {
      "kind": "specular/glass",
      "color": [
        0.22,
        0.32,
        0.36
      ],
      "transmission": 0.62,
      "roughness": 0.02,
      "ior": 1.46
    },
    "mat_cobalt_ceramic": {
      "kind": "glossy ceramic",
      "color": [
        0.02,
        0.12,
        0.72
      ],
      "roughness": 0.08,
      "clearcoat": 1.0
    },
    "mat_terracotta_ribbed": {
      "kind": "matte ribbed clay",
      "color": [
        0.74,
        0.3,
        0.14
      ],
      "roughness": 0.72
    },
    "mat_white_porcelain": {
      "kind": "pearlescent porcelain",
      "color": [
        0.9,
        0.86,
        0.78
      ],
      "roughness": 0.16,
      "specular": 0.85
    },
    "mat_dark_brushed_metal": {
      "kind": "brushed metal",
      "color": [
        0.08,
        0.08,
        0.09
      ],
      "metallic": 1.0,
      "roughness": 0.28
    }
  },
  "quality_checklist": [
    "Scene contains at least five distinct vases with visibly different silhouettes.",
    "Materials read differently: transparent glass, glossy ceramic, matte ribbed clay, smooth porcelain, and dark metal.",
    "Softbox reflections appear on glossy/glass/metal surfaces without clipping the whole image.",
    "Pedestal and cyclorama produce a credible studio-product photography composition.",
    "Native Octane output is saved as octane-preview.png before claiming native render success."
  ],
  "known_pitfalls": [
    "OBJ/MTL material hints cannot express full Octane glass, anisotropic metal, or clearcoat; use scene.json material intent when promoting to native material commands.",
    "Ribbed/brush texture is approximated with geometry and MTL values until texture/normal-map payloads exist.",
    "photoreal-preview.png is a target reference, not proof that Octane rendered this exact scene.",
    "Transparent glass may import as opaque unless the bridge material schema gains transmission/IOR support."
  ],
  "assets": [
    "scene.obj",
    "scene.mtl",
    "photoreal-preview.png"
  ],
  "commands": [
    {
      "op": "import_geometry",
      "payload": {
