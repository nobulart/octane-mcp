        {"name": "strap_emphasis", "azimuth_degrees": 18, "elevation_degrees": 8},
        {"name": "top_down", "azimuth_degrees": 0, "elevation_degrees": 45}
      ],
      "visual_grammar_axes": ["dial_size", "strap_link_readability", "hand_pin_accuracy", "camera_distance", "material_contrast"],
      "evidence_pattern": "iterations/baseline-<variant>.png plus iterations/baseline-review.json"
    }
  },
